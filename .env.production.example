# Database (Railway provides this as DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT (generate strong random secrets for production)
JWT_SECRET=generate-a-random-64-char-string
JWT_REFRESH_SECRET=generate-another-random-64-char-string

# AI Service URL (Railway internal or external)
AI_SERVICE_URL=https://your-ai-engine.railway.app

# Client URL (Netlify)
CLIENT_URL=https://your-app.netlify.app

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Environment
NODE_ENV=production
PORT=3001
