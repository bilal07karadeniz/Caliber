# Database (Railway provides this as DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT (generate strong random secrets for production)
# Use: openssl rand -hex 32
JWT_SECRET=generate-a-random-64-char-string
JWT_REFRESH_SECRET=generate-another-random-64-char-string

# AI Service URL (Railway internal or external)
AI_SERVICE_URL=https://your-ai-engine.railway.app
AI_API_KEY=generate-a-random-api-key

# Client URL (Netlify)
CLIENT_URL=https://your-app.netlify.app

# CORS origins (comma-separated, include your Netlify URL)
CORS_ORIGINS=https://your-app.netlify.app

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=Caliber <noreply@yourdomain.com>

# File Uploads (Railway volume mount path)
UPLOAD_DIR=/data/uploads

# Redis
REDIS_URL=redis://redis-host:6379

# Environment
NODE_ENV=production
PORT=3001

# AI Engine specific
ASYNC_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
SPACY_MODEL=en_core_web_sm
UPLOADS_DIR=/data/uploads

# Netlify (set BACKEND_URL in Netlify env vars)
# BACKEND_URL=https://your-backend.railway.app
