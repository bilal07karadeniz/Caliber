# ===========================================
# Server Environment Variables
# ===========================================

# PostgreSQL connection string
# Railway: auto-provided when you reference PostgreSQL service
# Example: postgresql://postgres:xxxx@postgres.railway.internal:5432/railway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caliber

# JWT secrets for authentication (REQUIRED in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# AI Engine URL (internal Railway URL, NOT public)
# Railway: http://ai-engine.railway.internal:8000
AI_SERVICE_URL=http://localhost:8000

# Shared API key between server and ai-engine (must match AI_KEY in ai-engine)
# Generate with: openssl rand -hex 16
AI_API_KEY=

# Frontend URL (your Netlify domain, used for CORS)
# Railway: https://your-app.netlify.app
CLIENT_URL=http://localhost:5173

# File upload directory
# Railway: /app/uploads (must match volume mount path)
UPLOAD_DIR=./uploads

# Environment
# Railway: production
NODE_ENV=development

# Email service (optional)
# RESEND_API_KEY=re_xxxxxxxxxx
# EMAIL_FROM=Caliber <noreply@yourdomain.com>
