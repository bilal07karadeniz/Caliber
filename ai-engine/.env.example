# ===========================================
# AI Engine Environment Variables
# ===========================================

# PostgreSQL connection string (sync driver)
# Railway: auto-provided when you reference PostgreSQL service
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caliber

# PostgreSQL connection string (async driver - REQUIRED)
# Same as DATABASE_URL but replace postgresql:// with postgresql+asyncpg://
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/caliber

# spaCy NLP model name (installed in Dockerfile)
SPACY_MODEL=en_core_web_sm

# Shared API key (must match AI_API_KEY in server)
# Generate with: openssl rand -hex 16
API_KEY=

# Allowed CORS origins (comma-separated)
# Railway: https://your-app.netlify.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Temp directory for uploaded files (ai-engine doesn't need a volume)
UPLOADS_DIR=/tmp
