# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caliber
POSTGRES_DB=caliber
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT (change these in production!)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=

# Client
CLIENT_URL=http://localhost:5173
VITE_API_URL=/api

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=Caliber <onboarding@resend.dev>

# File Uploads (local path, or Railway volume mount)
UPLOAD_DIR=./uploads

# Redis
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
